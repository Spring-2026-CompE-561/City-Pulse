# Copy to .env and set values. Do not commit .env (secrets).

# --- MySQL (default) ---
# If DATABASE_URL is unset, this URL is built from MYSQL_* below.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=city_pulse
MYSQL_PASSWORD=
MYSQL_DATABASE=city_pulse

# Or set a full URL to override (MySQL or SQLite):
# DATABASE_URL=mysql+asyncmy://user:password@localhost:3306/city_pulse?charset=utf8mb4
# DATABASE_URL=sqlite+aiosqlite:///./city_pulse.db

# --- App ---
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=60
